# Web RTC Client Environment Configuration
# ============================================================
# Copy this file to .env.client:  cp env.client.example .env.client
#
# These override values in config-client.yml
# ============================================================

# ─────────────────────────────────────────────────────────────
# LiveKit Server Connection
# ─────────────────────────────────────────────────────────────
# Local development
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Remote LiveKit Server
# LIVEKIT_URL=wss://your-server.com:7880
# LIVEKIT_API_KEY=your-api-key
# LIVEKIT_API_SECRET=your-api-secret

# LiveKit Cloud (https://cloud.livekit.io)
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your-api-key
# LIVEKIT_API_SECRET=your-api-secret

# ─────────────────────────────────────────────────────────────
# Client Settings
# ─────────────────────────────────────────────────────────────
# Room name (must match server)
# ROOM=Web RTC-room

# Client identity (unique per client)
# IDENTITY=user
